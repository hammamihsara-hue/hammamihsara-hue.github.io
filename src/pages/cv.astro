---

<Codex
  title="cv"
  description="Curriculum vitae of Sara H. Hammami — librarian, artist, poet & translator."
  folioStart={14}
  folioEnd={14}
  edgeLabel="back matter"
>
  <div class="cv-page">
    <h1 class="cv-title">Curriculum Vitae</h1>
    <p class="cv-contact">
      <a class="thread-link" href="mailto:hammamihsara@gmail.com">hammamihsara@gmail.com</a>
    </p>
    <p class="cv-download">
      <a class="thread-link thread-link--sewn" href="/Hammami_Sara_CV.pdf" download>
        download the full cv (pdf)
      </a>
    </p>

    <div class="cv-grid">
      {
        sections.map((section) => (
          <section class="cv-section">
            <span class="label">{section.label}</span>
            {section.entries.map((entry) => (
              <p class="cv-entry">
                <span class="what">{entry.what}</span>
                {entry.who && (
                  <>
                    <br />
                    <span class="who">{entry.who}</span>
                  </>
                )}
                {entry.when && (
                  <>
                    <br />
                    <span class="when">{entry.when}</span>
                  </>
                )}
              </p>
            ))}
          </section>
        ))
      }
    </div>

    <p class="colophon">
      this site is set in Cormorant Garamond, EB Garamond, Archivo &amp;
      Amiri; the poems keep their manuscript setting in Times. built as a
      book, 2026. photographs &amp; texts © Sara H. Hammami.
    </p>
  </div>
</Codex>
