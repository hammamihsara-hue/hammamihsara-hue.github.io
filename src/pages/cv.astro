---
import BookViewer from '../components/BookViewer.astro';
import Codex from '../layouts/Codex.astro';
---

<Codex
  title="cv"
  description="Curriculum vitae of Sara H. Hammami — librarian, artist, poet & researcher."
  folioStart={14}
  folioEnd={14}
  edgeLabel="back matter"
>
  <div class="cv-reader">
    <BookViewer
      title="Sara H. Hammami — Curriculum Vitae"
      pageDirectory="/media/cv"
      pageCount={2}
      singlePages
      pdfSrc="/Hammami_Sara_CV.pdf"
      pdfLabel="open the complete cv as a PDF ↗"
      pdfMeta="2 pages"
    />
  </div>
</Codex>
