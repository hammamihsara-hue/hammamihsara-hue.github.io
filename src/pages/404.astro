---
import Codex from '../layouts/Codex.astro';
---

<Codex title="page not bound" folioStart={1} folioEnd={1}>
  <section class="not-bound">
    <p class="ornament-head">404</p>
    <p style="font-style: italic; max-width: 26rem;">
      this page is not bound into this volume — it may have been cut, or is
      still being written.
    </p>
    <p>
      <a class="thread-link thread-link--sewn" href="/">return to the cover</a>
    </p>
  </section>
</Codex>
