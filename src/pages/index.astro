---
import { Image } from 'astro:assets';
import Codex from '../layouts/Codex.astro';
import { TOC } from '../lib/toc';
import cover from '../content/works/chasing-the-sun/plate-tree.jpg';
import coral from '../assets/coral.jpg';
import portrait from '../assets/portrait.jpg';
---

<Codex folioStart={1} folioEnd={1} canvas="plate">
  <section class="cover" data-hero-dark>
    <div class="plate-frame" data-light>
      <Image
        src={cover}
        alt=""
        widths={[820, 1400, 2200]}
        sizes="100vw"
        loading="eager"
        quality={80}
      />
      <div class="plate-light" aria-hidden="true"></div>
    </div>
    <div class="cover-titles">
      <div class="cover-names">
        <h1 class="cover-name">sara h. hammami</h1>
        <p class="cover-arabic" lang="ar" dir="rtl">سارة ه. حمامي</p>
      </div>
      <p class="cover-role label">librarian · artist · poet · researcher</p>
    </div>
  </section>

  <section class="spread" id="spread" aria-label="about and contents">
    <div class="page page-verso">
      <h2 class="ornament-head">About</h2>
      <div class="bio">
        <p>
          <strong>sara h. hammami</strong>{' '}is a multidisciplinary artist and
          librarian interested in poetics as a method to maneuver translation,
          archives, research, disability and storytelling. her work has been
          presented in Saudi Arabia and the United States, including{' '}
          <em>Sindbad: I Can See Land,</em>{' '}at Bait Al Sharbatly, Jeddah,
          Saudi Arabia (2024), <em>Speculating the Environment</em> at Pratt
          Institute, New York, United States (2023), and{' '}
          <em>Art of the Book</em> at Pratt Library, New York, United States
          (2023).
        </p>
        <p>
          hammami’s poetry has been published with ANMLY, Grist, and DEAR Poetry
          Journal, among other literary journals. she performed and given
          readings at <em>TONGUES: ANMLY Multilingual Reading</em> (2025),{' '}
          <em>Earthseed</em>, with The Crucible at New York City Jewelry Week
          (2022), and was a finalist at FEMS Tournament (2019). she has also
          participated in residencies including <em>Masaha</em> at Misk Art
          Institute, Saudi Arabia (2026), <em>Rewilding the Kitchen</em> with the
          Diriyah Contemporary Biennale, Saudi Arabia (2025) and{' '}
          <em>Image Text</em> at Cornell University, United States (2023).
        </p>
        <p>
          hammami develops curatorial and educational projects and programs,
          and is particularly interested in multidisciplinary and alternative
          research practices. she has led writing and research development
          workshops and programs, most notably at MISK Art Institute, the
          Diriyah Contemporary Biennale, Art Jameel, and the PaperBack Art Book
          Fair. hammami launched the Hayy Library in 2025, working on
          comprehensive and long term cultural aims with a focus on: literacy,
          accessibility and alternative research practices.
        </p>
        <p>
          currently, her projects are curious about the translational quality
          of city/borders, alternative time-keeping and realities, as well as
          the translucent qualities of the sea. she is always thinking and
          dreaming of life underwater.
        </p>
        <figure class="tipped-in tipped-in--straight">
          <div class="plate-frame" data-light>
            <Image src={portrait} alt="Sara, photographed from behind in black and white, dark curls against a soft riverside light." widths={[420, 820]} sizes="17rem" quality={80} />
            <div class="plate-light" aria-hidden="true"></div>
          </div>
        </figure>
      </div>
    </div>

    <div class="page page-recto">
      <h2 class="ornament-head">Contents</h2>
      <div class="contents-page">
        <ol class="toc">
          {
            TOC.map((entry) => (
              <li>
                <a href={entry.href}>
                  <span class="toc-row">
                    <span class="toc-label">{entry.label}</span>
                    {entry.note && <span class="toc-note">{entry.note}</span>}
                    <span class="leader" />
                    <span class="toc-folio">{entry.folio}</span>
                  </span>
                </a>
              </li>
            ))
          }
        </ol>
        <p class="inquire">
          <a class="thread-link thread-link--sewn" href="mailto:hammamihsara@gmail.com">
            inquire — hammamihsara@gmail.com
          </a>
        </p>
        <figure class="tipped-in">
          <Image src={coral} alt="A green coral head on pale sand, seen through shallow prismatic water." widths={[420, 820]} sizes="17rem" quality={80} />
          <figcaption>the red sea, translucent</figcaption>
        </figure>
      </div>
    </div>
  </section>
</Codex>
